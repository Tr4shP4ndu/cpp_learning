# Ignore centralized build artifacts (also matches apps/<project>/build/)
build/

# Self-contained toolchain installed by `make install` — never committed
toolchain/

# Learners' personal scratch copies (make practice ...)
practice/

# Rendered output from the capstone (63-mini-renderer) + the renderer lessons
*.ppm
*.png
# ...but the committed test textures under assets/ are the exception
!assets/**/*.ppm

# macOS metadata (harmless extra)
.DS_Store

.vscode/
